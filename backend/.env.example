# Para desarrollo local del backend (cuando NO se usa docker-compose)
# Copia este archivo a .env y ajusta. En producción usa el .env raíz del repo.

NODE_ENV=development
BACKEND_PORT=3001
PUBLIC_APP_URL=http://localhost:3000
PUBLIC_API_URL=http://localhost:3001

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=callcenter
MYSQL_USER=callcenter
MYSQL_PASSWORD=callcenter

REDIS_HOST=127.0.0.1
REDIS_PORT=6379

JWT_SECRET=change_me_with_64_random_bytes_hex_change_me_with_64_random_bytes
JWT_REFRESH_SECRET=change_me_with_another_64_random_bytes_hex_change_me_with_another
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
