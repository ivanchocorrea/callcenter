# ============================================================
#  Call Center NODOE — Variables de entorno
#  Copia este archivo a .env y rellena los valores.
# ============================================================

# ----- App -----
NODE_ENV=development
PUBLIC_APP_URL=https://app.localhost
PUBLIC_API_URL=https://api.localhost

# ----- Backend -----
BACKEND_PORT=3001
BACKEND_HOST=0.0.0.0

# ----- Frontend -----
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=https://api.localhost
NEXT_PUBLIC_WS_URL=wss://api.localhost
NEXT_PUBLIC_SIP_WSS_URL=wss://sip.localhost:8089/ws

# ----- MySQL -----
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DATABASE=callcenter
MYSQL_USER=callcenter
MYSQL_PASSWORD=change_me_strong
MYSQL_ROOT_PASSWORD=change_me_root_strong

# ----- Redis -----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ----- JWT -----
JWT_SECRET=change_me_with_64_random_bytes_hex
JWT_REFRESH_SECRET=change_me_with_another_64_random_bytes_hex
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ----- Encryption (AES-256-GCM master key, 32 bytes hex = 64 chars) -----
ENCRYPTION_MASTER_KEY=replace_me_with_64_hex_chars_0000000000000000000000000000000000

# ----- Asterisk AMI -----
ASTERISK_HOST=asterisk
ASTERISK_AMI_PORT=5038
ASTERISK_AMI_USER=admin
ASTERISK_AMI_PASSWORD=change_me_ami

# ----- Asterisk ARI -----
ASTERISK_ARI_HOST=asterisk
ASTERISK_ARI_PORT=8088
ASTERISK_ARI_USER=ariadmin
ASTERISK_ARI_PASSWORD=change_me_ari
ASTERISK_ARI_APP=callcenter-app

# ----- Storage -----
STORAGE_DRIVER=local
LOCAL_RECORDINGS_PATH=/var/recordings
# para S3-compatible:
S3_ENDPOINT=
S3_REGION=us-east-1
S3_BUCKET=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_FORCE_PATH_STYLE=true

# ----- Email transaccional (SMTP) -----
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=no-reply@example.com
SMTP_FROM_NAME=Call Center NODOE

# ----- Rate limit -----
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# ----- CORS -----
CORS_ORIGINS=https://app.localhost,http://localhost:3000

# ----- Logs / Observability -----
LOG_LEVEL=info
LOG_FORMAT=json
ENABLE_METRICS=true
ENABLE_TRACING=false
OTEL_EXPORTER_OTLP_ENDPOINT=

# ----- Bootstrap del super_admin (solo se usa la primera vez) -----
BOOTSTRAP_SUPERADMIN_EMAIL=admin@nodoe.test
BOOTSTRAP_SUPERADMIN_PASSWORD=ChangeMeNow!2026
BOOTSTRAP_SUPERADMIN_NAME=Super Admin
